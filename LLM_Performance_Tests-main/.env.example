# ═══════════════════════════════════════════════════════════
#  LLM Benchmark – Konfiguration
#  Kopiere diese Datei nach .env und passe die Werte an.
# ═══════════════════════════════════════════════════════════

# ── Globale API-Keys ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Modell-Definitionen (JSON-Array) ─────────────────────
# Pflichtfelder:  provider, model_id, label
# Optionale:      base_url  (für eigene Server)
#                 api_key   (überschreibt globalen Key für dieses Modell)
#                 timeout_s (überschreibt globales TIMEOUT_S)
#
# Provider-Werte:
#   "anthropic"          → Anthropic API
#   "openai"             → OpenAI API
#   "openai_compatible"  → beliebiger OpenAI-kompatibler Server
#                          (vLLM, Ollama, LM Studio, llama.cpp, …)
#
MODELS=[
  {"provider": "anthropic",         "model_id": "claude-haiku-4-5",  "label": "Claude Haiku"},
  {"provider": "anthropic",         "model_id": "claude-sonnet-4-6", "label": "Claude Sonnet"},
  {"provider": "openai",            "model_id": "gpt-4o-mini",       "label": "GPT-4o mini"},
  {"provider": "openai_compatible", "model_id": "llama-3.1-8b-instruct", "label": "Llama Server 1",
   "base_url": "http://192.168.1.10:8000/v1", "api_key": "none"},
  {"provider": "openai_compatible", "model_id": "mistral-7b-instruct",   "label": "Mistral Server 2",
   "base_url": "http://192.168.1.11:8000/v1", "api_key": "none"}
]

# ── Prompts ───────────────────────────────────────────────
#
# Option A: externe JSON-Datei (empfohlen für große Prompt-Pools)
#   Pfad relativ zum Projektverzeichnis oder absolut.
#   Format: ["Prompt 1", "Prompt 2", ...]
#
PROMPTS_FILE=prompts.json
#
# Option B: direkt in der .env (wird ignoriert wenn PROMPTS_FILE gesetzt)
#
# PROMPTS=[
#   "Erkläre in einem Satz, was Quantencomputing ist.",
#   "Was ist die Hauptstadt von Australien?",
#   "Schreibe eine kurze Python-Funktion, die zwei Zahlen addiert."
# ]

# ── Test-Parameter ────────────────────────────────────────
#
# CALL_COUNTS: Anzahl verschiedener Prompts pro Experiment.
#   Für jeden Wert werden N eindeutige Prompts aus dem Pool gezogen
#   (kein Repeat → kein Cache-Hit). Seq und Par laufen über dieselben Prompts.
CALL_COUNTS=[1,3,6,10]
#
# PROMPT_SELECTION: Wie Prompts aus dem Pool gewählt werden.
#   "first"  → die ersten N Prompts (deterministisch, reproduzierbar)
#   "random" → zufällig N Prompts (jeder Lauf anders)
PROMPT_SELECTION=first
#
# MAX_TOKENS_LIST: Token-Limits für die Experimente.
#   Für jeden Wert × jeden CALL_COUNT wird ein vollständiger Durchlauf gemacht.
MAX_TOKENS_LIST=[256,1024]
#
TIMEOUT_S=30          # Timeout pro Call in Sekunden

# ── MLflow ────────────────────────────────────────────────
MLFLOW_EXPERIMENT=llm-benchmark
MLFLOW_TRACKING_URI=           # leer = lokales ./mlruns Verzeichnis
                               # z.B. http://localhost:5000 für Remote-Server
