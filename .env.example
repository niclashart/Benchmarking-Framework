# ─── Shared defaults (used when per-role vars are not set) ─────
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=

# ─── OpenAI-compatible endpoint ───────────────────────────────
# For vLLM, TGI, LM Studio, or any OpenAI-compatible server.
# OPENAI_COMPAT_BASE_URL=https://optimaise.ddnss.de/v1
# OPENAI_COMPAT_API_KEY=

# ─── Per-role URL overrides ──────────────────────────────────
# Each falls back to the shared default above if left unset.
# Use these when different models run on different machines.

# Generator LLM (question answering) — overrides shared OLLAMA/OPENAI_COMPAT URLs
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_API_KEY=
# LLM_OPENAI_COMPAT_BASE_URL=https://optimaise.ddnss.de/v1
# LLM_OPENAI_COMPAT_API_KEY=

# Critic LLM (RAGAS evaluation) — overrides shared OLLAMA/OPENAI_COMPAT URLs
# EVAL_CRITIC_OLLAMA_BASE_URL=http://dgx-spark:11434
# EVAL_CRITIC_OLLAMA_API_KEY=
# EVAL_CRITIC_OPENAI_COMPAT_BASE_URL=https://rtx-server/v1
# EVAL_CRITIC_OPENAI_COMPAT_API_KEY=

# Embeddings (always Ollama) — overrides shared OLLAMA URL
# EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_OLLAMA_API_KEY=

# ─── Models ───────────────────────────────────────────────────
# Use "ollama:" or "openai:" prefix to pick the provider.
# No prefix defaults to ollama (local or remote, depending on URL config).
LLM_MODELS=ollama:gemma3:4b
# LLM_MODELS=ollama:gemma3:4b,openai:Qwen/Qwen3-32B-AWQ

# Embedding models — use "ollama:" (default) or "huggingface:" prefix.
# HuggingFace models run locally in-process (no server needed).
EMBEDDING_MODELS=nomic-embed-text:latest
# EMBEDDING_MODELS=huggingface:BAAI/bge-small-en-v1.5
CHUNK_SIZES=500
CHUNK_OVERLAPS=100
CHUNKING_STRATEGIES=recursive
# Semantic chunking — add "semantic" to CHUNKING_STRATEGIES above to enable.
# Splits on embedding-based topic boundaries instead of fixed character counts.
# SEMANTIC_BREAKPOINT_TYPE=percentile       # percentile | standard_deviation | interquartile
# SEMANTIC_BREAKPOINT_AMOUNT=95             # threshold (higher = fewer/larger chunks)
RETRIEVAL_TOP_K=8
# Retrieval strategy: similarity (default) or mmr (Maximal Marginal Relevance — diversifies results).
# RETRIEVAL_STRATEGY=similarity
# RETRIEVAL_FETCH_K=20
# RETRIEVAL_MMR_LAMBDA=0.5         # 0 = max diversity, 1 = max relevance

# HyDE: use the generator LLM to produce a hypothetical answer, then embed that
# instead of the raw question.  Improves retrieval for short/terse queries.
# RETRIEVAL_USE_HYDE=false

MAX_NEW_TOKENS=512

# ─── Execution stage and vector store ─────────────────────────
# BENCHMARK_STAGE: all | index | query
#   all   — previous end-to-end behavior
#   index — chunk/embed/index only
#   query — reuse persisted index, then retrieve/generate/evaluate
# Keep defaults unless you want index/query split or LanceDB.
BENCHMARK_STAGE=all
VECTOR_DB_BACKEND=chroma        # chroma | lancedb
LANCEDB_PATH=.lancedb
#
# Index/query split example:
#   BENCHMARK_STAGE=index python main.py
#   BENCHMARK_STAGE=query python main.py
#
# LanceDB example:
#   VECTOR_DB_BACKEND=lancedb
#   LANCEDB_PATH=.lancedb

# Generator answer post-processing (Qwen / reasoning models)
# LLM_ANSWER_STRIP_MODE: full | tags_only | off
#   full — strip <think>...</think> blocks, then drop output that still looks like reasoning (old default behavior)
#   tags_only  — strip <think>...</think> only (default; avoids empty answers for chatty models)
#   off        — raw model string (only .strip())
# LLM_ANSWER_STRIP_MODE=tags_only
# If the answer is still empty, scan from the last line for a number or yes/no (FinQA-style).
# LLM_ANSWER_VALUE_FALLBACK=true

# ─── Prompt templates ──────────────────────────────────────────
# Comma-separated list of prompt template names to sweep.
# Built-in templates: concise (raw values), detailed (full sentences), finqa (derivation trace).
# PROMPT_TEMPLATES=concise,detailed
PROMPT_TEMPLATES=finqa

# ─── Reranker (optional) ──────────────────────────────────────
# Use "huggingface:" prefix for local cross-encoder rerankers.
# Leave empty / unset to disable reranking.
RERANKER_MODELS=huggingface:cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=3

# ─── Dataset ──────────────────────────────────────────────────
# DATASET_SOURCE:
#   builtin      — built-in adapters below (default)
#   huggingface  — arbitrary Hugging Face dataset with DATASET_MAPPING
#   jsonl        — local JSONL eval file
#   csv          — local CSV eval file
#   corpus_jsonl — separate searchable corpus + benchmark questions JSONL files
DATASET_SOURCE=builtin

# Built-in adapters: t2-ragbench, ragbench, squad, ragas-wikiqa, ragperf-wikipedia-nq
# Default FinQA setup:
DATASET_NAME=t2-ragbench
DATASET_SUBSET=FinQA
DATASET_SAMPLE_SIZE=50
# Optional for DATASET_SOURCE=huggingface:
# DATASET_SPLIT=test
#
# Optional/required mapping for custom sources. Keys are canonical benchmark
# fields; values are source column names. "metadata" keeps extra source fields.
# Default canonical names are question, ground_truth, context, id,
# relevant_context_ids, and text.
# DATASET_MAPPING={"question":"query","ground_truth":"answer","context":"ctx","id":"id","metadata":["title","source"]}
#
# RAGBench subsets: covidqa, cuad, delucionqa, emanual, expertqa,
#   finqa, hagrid, hotpotqa, msmarco, pubmedqa, tatqa, techqa
#
# SQuAD shared-corpus setup:
#   DATASET_NAME=squad
#   DATASET_SUBSET=
#   DATASET_SAMPLE_SIZE=50
#
# RAGAS WikiQA setup:
#   DATASET_NAME=ragas-wikiqa
#   DATASET_SUBSET=
#   DATASET_SAMPLE_SIZE=50
#
# RAGPerf-style Wikipedia + Natural Questions setup:
#   DATASET_NAME=ragperf-wikipedia-nq
#   DATASET_SUBSET=
#   DATASET_SAMPLE_SIZE=50
#   RAGPERF_WIKIPEDIA_CORPUS_SIZE=1000
# Notes: answer ground truth exists, but gold Wikipedia document/chunk IDs do not.
#
# Arbitrary Hugging Face dataset example:
#   DATASET_SOURCE=huggingface
#   DATASET_NAME=rajpurkar/squad
#   DATASET_SUBSET=
#   DATASET_SPLIT=validation
#   DATASET_MAPPING={"question":"question","ground_truth":"answers","context":"context","id":"id","metadata":["title"]}
#
# Local JSONL/CSV examples:
#   DATASET_SOURCE=jsonl
#   DATASET_PATH=data/eval.jsonl
#   DATASET_MAPPING={"question":"query","ground_truth":"answer","context":"ctx","id":"id"}
#
#   DATASET_SOURCE=csv
#   DATASET_PATH=data/eval.csv
#   DATASET_MAPPING={"question":"query","ground_truth":"answer","context":"ctx","id":"id"}
#
# Separate corpus + questions JSONL example:
#   DATASET_SOURCE=corpus_jsonl
#   DATASET_CORPUS_PATH=data/corpus.jsonl
#   DATASET_QUESTIONS_PATH=data/questions.jsonl
#   DATASET_MAPPING={"question":"question","ground_truth":"ground_truth","id":"id","text":"text","relevant_context_ids":"relevant_context_ids"}

# ─── RAGAS evaluation critic ─────────────────────────────────
EVAL_CRITIC_LLM=ollama:gemma3:12b
EVAL_CRITIC_EMBEDDING=nomic-embed-text:latest
EVAL_CRITIC_MAX_TOKENS=4096

# ─── MLflow tracking ─────────────────────────────────────────
# Local file store (default – no server needed):
#   MLFLOW_TRACKING_URI=mlruns
# Or a full tracking server:
#   MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_TRACKING_URI=mlruns

# ─── LangFuse tracing ──────────────────────────────────────
# Additive observability layer — does not replace MLflow.
# Enable by uncommenting after creating a project at http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000
