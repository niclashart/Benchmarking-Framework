# Minimal runtime environment.
# Keep workflow configuration in YAML and secrets/service URLs here.

# General benchmark config entrypoint used by python main.py.
# Override this per run, or omit it to fall back to the legacy .env matrix.
BENCHMARK_CONFIG_FILE=experiments/full-grid-example.yaml

# Shared Ollama endpoint. Used by generator, critic, and embeddings unless a
# per-role override below is set.
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=

# OpenAI-compatible endpoint for vLLM, TGI, LM Studio, or remote model servers.
# OPENAI_COMPAT_BASE_URL=https://optimaise.ddnss.de/v1
# OPENAI_COMPAT_API_KEY=

# Optional per-role URL/API-key overrides. Leave unset to use the shared values.
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_API_KEY=
# LLM_OPENAI_COMPAT_BASE_URL=https://optimaise.ddnss.de/v1
# LLM_OPENAI_COMPAT_API_KEY=
# EVAL_CRITIC_OLLAMA_BASE_URL=http://dgx-spark:11434
# EVAL_CRITIC_OLLAMA_API_KEY=
# EVAL_CRITIC_OPENAI_COMPAT_BASE_URL=https://rtx-server/v1
# EVAL_CRITIC_OPENAI_COMPAT_API_KEY=
# EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_OLLAMA_API_KEY=

# External HTTP RAG systems can keep auth out of YAML/source.
# RAG_SYSTEM_ADAPTER=http
# RAG_HTTP_ENDPOINT_URL=http://localhost:8000/query
# RAG_HTTP_ANSWER_FIELD=answer
# RAG_HTTP_CONTEXTS_FIELD=contexts
# RAG_HTTP_METADATA_FIELD=metadata
# RAG_HTTP_TIMINGS_FIELD=timings
# RAG_HTTP_AUTH_HEADER=Authorization
# RAG_HTTP_AUTH_VALUE=Bearer ${RAG_API_TOKEN}
# RAG_HTTP_HEADERS={"X-Project":"benchmark"}
# RAG_ADAPTER_MODULES=my_package.my_adapter

# Local JSONL/CSV datasets for quick external-RAG evaluation.
# DATASET_NAME=jsonl
# DATASET_PATH=examples/sample_dataset.jsonl
# DATASET_QUESTION_FIELD=question
# DATASET_GROUND_TRUTH_FIELD=ground_truth
# DATASET_CONTEXT_FIELD=context
# DATASET_METADATA_FIELD=metadata

# Disable expensive model-based metrics for endpoint smoke tests.
# RAGAS_ENABLED=false
# CUSTOM_METRICS_ENABLED=false

# MLflow tracking and MLflow-specific runtime toggles stay in env.
# Provider credentials expected by MLflow should also stay here.
MLFLOW_TRACKING_URI=mlruns
# OPENAI_API_KEY=

# ClearML remote execution. These configure ClearML itself, not the benchmark
# matrix. The ClearML task publishes only non-secret BenchmarkConfig fields.
# CLEARML_WEB_HOST=http://localhost:8080
# CLEARML_API_HOST=http://localhost:8008
# CLEARML_FILES_HOST=http://localhost:8081
# CLEARML_API_ACCESS_KEY=
# CLEARML_API_SECRET_KEY=

# LangFuse tracing.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000

# Legacy fallback: if BENCHMARK_CONFIG_FILE is unset, config.py still accepts the
# old .env matrix variables such as LLM_MODELS, EMBEDDING_MODELS, CHUNK_SIZES,
# DATASET_NAME, RETRIEVAL_TOP_K, PROMPT_TEMPLATES, and RERANKER_MODELS.
